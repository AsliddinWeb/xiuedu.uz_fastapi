# ═══════════════════════════════════════════════════════════════
#  XIU Edu — Production .env.prod
#
#  Bu faylni serverda .env.prod deb nomlang:
#    cp .env.prod.example .env.prod
#    nano .env.prod
# ═══════════════════════════════════════════════════════════════

# ===== Database (tashqi PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://xiuedu_fastapi_user:PAROL@127.0.0.1:5432/xiuedu_fastapi_fb

# ===== Redis =====
REDIS_URL=redis://127.0.0.1:6379/0

# ===== Security =====
# openssl rand -hex 32 bilan generatsiya qiling:
SECRET_KEY=BU_YERNI_OZGARTIRING_64_BELGIDAN_ORTIQ_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ===== CORS =====
ALLOWED_ORIGINS=https://xiuedu.uz,https://www.xiuedu.uz

# ===== Site =====
SITE_URL=https://xiuedu.uz
SITE_NAME=Xalqaro Innovatsion Universiteti
UPLOAD_DIR=/var/www/xiuedu-media
MAX_UPLOAD_SIZE_MB=20

# ===== Admin =====
ADMIN_EMAIL=admin@xiuedu.uz
ADMIN_PASSWORD=KUCHLI_PAROL_QOYING

# ===== AI Chat (Groq) =====
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Frontend =====
VITE_API_BASE_URL=https://xiuedu.uz/api
VITE_SITE_URL=https://xiuedu.uz
