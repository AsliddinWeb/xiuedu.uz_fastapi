          class="fixed inset-0 z-[120] bg-[#0A0D3D]/95 backdrop-blur-sm flex items-center justify-center p-6"
          @click.self="closeLicense"
        >
          <button
            type="button"
            class="absolute top-5 right-5 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white grid place-items-center"
            @click="closeLicense"
          >
            <XMarkIcon class="w-5 h-5" />
          </button>
          <button
            v-if="licenses.length > 1"
            type="button"
            class="absolute left-5 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white grid place-items-center"
            @click="prevLicense"
