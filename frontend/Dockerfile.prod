# Frontend production build
FROM node:20-alpine AS builder

WORKDIR /app
COPY package.json ./
RUN npm install --ignore-scripts && npm install @rollup/rollup-linux-x64-musl --save-optional
COPY . .

ARG VITE_API_BASE_URL=https://xiuedu.uz/api
ARG VITE_SITE_URL=https://xiuedu.uz
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SITE_URL=$VITE_SITE_URL

RUN npm run build

FROM alpine:3.19
COPY --from=builder /app/dist /app/dist
CMD ["echo", "Frontend built"]
