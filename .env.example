# ===== Database =====
POSTGRES_USER=xiuedu
POSTGRES_PASSWORD=xiuedu_secret
POSTGRES_DB=xiuedu
DATABASE_URL=postgresql+asyncpg://xiuedu:xiuedu_secret@db:5432/xiuedu

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Backend / Security =====
SECRET_KEY=change-me-to-a-long-random-string-please
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost,http://localhost:5176,http://localhost:8014,https://xiuedu.uz

# ===== Site / Uploads =====
SITE_URL=https://xiuedu.uz
SITE_NAME=Xalqaro Innovatsion Universiteti
UPLOAD_DIR=/app/media
MAX_UPLOAD_SIZE_MB=20

# ===== Admin =====
ADMIN_EMAIL=admin@xiuedu.uz
ADMIN_PASSWORD=ChangeMe123!

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost/api
VITE_SITE_URL=https://xiuedu.uz
